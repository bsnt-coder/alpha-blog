<h1>Showing article details</h1>
<p><strong>Title: </strong> <%=@article.title %></p>
<p><strong>Description: </strong> <%=@article.description %></p>
<p>
  <button><%= link_to 'Edit', edit_article_path(@article.id), data:{turbo_method: :get} %></button>
  <button><%= link_to 'Back to listing', articles_path, data:{turbo_method: :get} %></button>
  <button><%= link_to 'Delete', article_path(@article.id), data:{turbo_method: :delete, turbo_confirm: "Are you sure?"} %></button>
</p>